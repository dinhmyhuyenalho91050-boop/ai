<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chat_bg"
    android:fitsSystemWindows="false">

    <LinearLayout
        android:id="@+id/app_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/header_bar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/bg_header">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/title_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/app_title"
                    android:textColor="@color/chat_title"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/version_pill"
                    android:layout_width="61dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="10dp"
                    android:visibility="gone"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/app_version"
                    android:textColor="@color/chat_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_pill" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_sessions"
                style="@style/ChatButton"
                android:layout_width="86dp"
                android:layout_height="34dp"
                android:text="@string/action_sessions" />

            <TextView
                android:id="@+id/btn_settings"
                style="@style/ChatButton"
                android:layout_width="60dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:text="@string/action_settings" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/chat_frame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:id="@+id/messages_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:paddingStart="8dp"
                android:paddingTop="14dp"
                android:paddingEnd="8dp"
                android:paddingBottom="18dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/messages_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/composer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="13dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_composer">

            <LinearLayout
                android:id="@+id/model_selector"
                android:layout_width="match_parent"
                android:layout_height="37dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="4dp"
                android:background="@drawable/bg_model_selector">

                <TextView
                    android:id="@+id/model_gpt"
                    style="@style/ModelTab"
                    android:text="@string/model_gpt" />

                <TextView
                    android:id="@+id/model_deepseek"
                    style="@style/ModelTab"
                    android:text="@string/model_deepseek" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/input_row"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="11dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/input_message"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:gravity="top|start"
                    android:hint="@string/input_hint"
                    android:imeOptions="actionSend"
                    android:includeFontPadding="false"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="5"
                    android:minLines="2"
                    android:overScrollMode="never"
                    android:paddingStart="16dp"
                    android:paddingTop="11dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="10dp"
                    android:scrollbars="none"
                    android:textColor="@color/chat_fg"
                    android:textColorHint="@color/chat_muted"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/btn_send"
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_button_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/action_send"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:layout_marginTop="60dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@drawable/bg_sidebar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp"
            android:background="@drawable/bg_sidebar_header">

            <LinearLayout
                android:id="@+id/sidebar_model_selector"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="4dp"
                android:background="@drawable/bg_model_selector">

                <TextView
                    android:id="@+id/sidebar_model_gpt"
                    style="@style/ModelTab"
                    android:text="@string/model_gpt" />

                <TextView
                    android:id="@+id/sidebar_model_deepseek"
                    style="@style/ModelTab"
                    android:text="@string/model_deepseek" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_new_chat"
                style="@style/ChatPrimaryButton"
                android:layout_width="62dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="@string/action_new_chat" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:padding="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/session_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>
</FrameLayout>
