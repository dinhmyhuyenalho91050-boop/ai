<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/chat_button_pressed" />
            <stroke android:width="1dp" android:color="@color/chat_accent_blue" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/chat_panel" />
            <stroke android:width="1dp" android:color="@color/chat_border" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
